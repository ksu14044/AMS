# 로컬 개발용 — 이 파일을 복사해 application-local.yaml 로 저장하세요.
# application-local.yaml 은 .gitignore 대상입니다.

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/ams?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: your_password_here

ams:
  jwt:
    # 최소 32자 이상 랜덤 문자열 (로컬 전용, git에 커밋하지 않음)
    secret: change-me-to-a-long-random-secret-at-least-32-chars
    login-select-expiration-ms: 300000
    # refresh-expiration-ms: application.yaml 기본 90일 (API 사용 시 access 자동 갱신)
  signup:
    frontend-base-url: http://localhost:5173
    # 학원 최초 개설 링크: POST /api/v1/auth/signup-invites/academy + 헤더 X-Ams-Bootstrap-Key
    academy-bootstrap-key: local-dev-bootstrap-key

# V29 등 이미 적용된 마이그레이션 SQL을 H2 호환으로 수정한 뒤 checksum 불일치 시 (로컬 MySQL 1회):
# PowerShell — -D 인자 전체를 따옴표로 감싸야 URL의 : 가 Maven에 잘못 파싱되지 않음
#   .\mvnw.cmd flyway:repair "-Dflyway.url=jdbc:mysql://localhost:3306/ams?serverTimezone=Asia/Seoul" "-Dflyway.user=root" "-Dflyway.password=YOUR_PASSWORD"
