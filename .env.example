# 서버 /opt/ams/.env — git에 커밋하지 마세요. cp .env.example .env 후 값 입력.

MYSQL_ROOT_PASSWORD=change-me-root
AMS_DB_USER=ams
AMS_DB_PASSWORD=change-me-db
AMS_JWT_SECRET=change-me-at-least-32-characters-long-secret

# 브라우저 접속 URL (http://공인IP 또는 https://도메인)
AMS_FRONTEND_BASE_URL=http://localhost

# 학원 최초 개설 API용 (선택)
# AMS_ACADEMY_BOOTSTRAP_KEY=

AMS_HTTP_PORT=80

# MySQL 호스트 바인딩 포트 (기본 3306). 로컬 PC에 MySQL이 3306을 쓰면 docker compose 시 3307 등으로 변경
# AMS_MYSQL_HOST_PORT=3306

# 운영 서버 /opt/ams/.env — GHCR 이미지 (수동 compose 시에도 필요)
# AMS_API_IMAGE=ghcr.io/<github-owner>/ams/api:latest
# AMS_WEB_IMAGE=ghcr.io/<github-owner>/ams/web:latest
